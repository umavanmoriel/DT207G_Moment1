<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Startsida</title>
        <link rel="stylesheet" href="/css/main.css">
        <link rel="stylesheet" href="/css/startpage.css">
        <script type="module" src="/js/headernav.js"></script>
    </head>
    <body>
        <header>
            <nav>
                <ul class="nav-list">
                    <li><a href="/startpage">Mina kurser</a></li>
                    <li><a href="/addcourse">Lägg till kurs</a></li>
                    <li><a href="/about">Om sidan</a></li>
                </ul>
            </nav>
        </header>
        <main class="courses-main">
            <h1>Mina kurser</h1>   
            <% if (courseList && courseList.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>Kurskod</th>
                            <th>Kursnamn</th>
                            <th>Kursplan</th>
                            <th>Progression</th>
                            <th>Radera kurs</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% courseList.forEach(course => { %>
                        <tr>
                            <td><%= course.courseCode %></td>
                            <td><%= course.courseName %></td>
                            <td><%= course.syllabus %></td>
                            <td><%= course.progression%></td>
                            <td>
                                <a href="/delete/<%= course.ID || course.id %>" class="deleteButton" onclick="return confirm('Är du säker att du vill radera denna kurs?')">Radera</a>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>Inga kurser tillagda än</p>
            <% } %>
        </main>
        <footer>
            <ul class="footer-list">
                <li>VT2025 DT207G</li>
                <li>Backend-baserad webbutveckling</li>
            </ul>
    </footer>
    </body>
</html>